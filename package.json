{
	"name": "public-website",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "react-router dev",
		"build": "pnpm build:assets:news && pnpm build:app",
		"typegen": "wrangler types && react-router typegen",
		"fix": "biome check --write",
		"check": "biome check",
		"prepare": "husky && react-router typegen && panda codegen",
		"build:assets:news": "tsx ./scripts/copy-article-assets.ts",
		"build:app": "react-router build"
	},
	"dependencies": {
		"@saitamau-maximum/markdown-processor": "^2.2.4",
		"isbot": "^5.1.40",
		"react": "^19.2.6",
		"react-aria-components": "^1.17.0",
		"react-dom": "^19.2.6",
		"react-feather": "^2.0.10",
		"react-router": "^7.15.0",
		"rehype-parse": "^9.0.1",
		"rehype-react": "^8.0.0",
		"unified": "^11.0.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@cloudflare/vite-plugin": "^1.36.3",
		"@pandacss/dev": "^1.11.1",
		"@react-router/dev": "^7.15.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.6.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"autoprefixer": "^10.5.0",
		"gray-matter": "^4.0.3",
		"husky": "^9.1.7",
		"js-yaml": "^4.1.1",
		"json-schema-to-ts": "^3.1.1",
		"lint-staged": "^17.0.4",
		"sass-embedded": "^1.99.0",
		"schema-dts": "^2.0.0",
		"sharp": "^0.34.5",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"valibot": "^1.4.0",
		"vite": "^8.0.11",
		"wrangler": "^4.90.0"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
