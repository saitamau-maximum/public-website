{
	"name": "public-website",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "react-router dev",
		"build": "cross-env NODE_OPTIONS=\"--conditions workerd\" react-router build",
		"typegen": "wrangler types && react-router typegen",
		"fix": "biome check --write",
		"check": "biome check",
		"prepare": "husky && react-router typegen && panda codegen"
	},
	"dependencies": {
		"@saitamau-maximum/markdown-processor": "^2.1.1",
		"isbot": "^5.1.31",
		"react": "^19.1.1",
		"react-aria-components": "^1.12.2",
		"react-dom": "^19.1.1",
		"react-feather": "^2.0.10",
		"react-router": "^7.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.4",
		"@pandacss/dev": "^1.4.0",
		"@react-router/dev": "^7.9.3",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.5.2",
		"@types/react": "^19.1.14",
		"@types/react-dom": "^19.1.9",
		"autoprefixer": "^10.4.21",
		"cross-env": "^10.1.0",
		"gray-matter": "^4.0.3",
		"husky": "^9.1.7",
		"js-yaml": "^4.1.0",
		"json-schema-to-ts": "^3.1.1",
		"lint-staged": "^16.2.1",
		"sass-embedded": "^1.93.2",
		"schema-dts": "^1.1.5",
		"typescript": "^5.9.2",
		"valibot": "^1.1.0",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"wrangler": "^4.40.2"
	},
	"lint-staged": {
		"*": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"packageManager": "pnpm@10.17.1"
}
